# Copy to .env and fill in. Do not commit .env.

# Browser Use (discriminator agent)
BROWSER_USE_API_KEY=

# Minimax (generator agent)
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=

# Target site (any URL)
TARGET_URL=https://e-commerce-website-build-six.vercel.app/

# Optional: describe what the site has so the generator only suggests valid workflows.
# If unset, a generic e-commerce description is used. Use for any site.
# SITE_DESCRIPTION=Header: Shop, Tops, Bottoms. No search. Click category, view product, add to cart.

# Optional: extra instructions for the browser agent (e.g. "Click product cards to open details").
# AGENT_INSTRUCTIONS=
