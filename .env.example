# ----- AgentVeil Environment Variables -----

# [Browser Use API]
# Required for the UI Agent to navigate headless browsers and catch visual React/DOM errors.
BROWSER_USE_API_KEY="your_browser_use_api_key_here"

# [MiniMax API]
# Required for the generative Fixer Agent to read error logs and output corrected code.
MINIMAX_API_KEY="your_minimax_api_key_here"
MINIMAX_GROUP_ID="your_minimax_group_id_here"

# [GitHub API]
# Required for the Fixer Agent to create branches and automatically submit Pull Requests with fixes.
# Ensure this token has 'repo' scope access.
GITHUB_TOKEN="your_github_personal_access_token"
